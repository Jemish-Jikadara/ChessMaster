<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChessMaster | About</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/theme-redesign.css">
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet">
    <style>
      /* ---------- Hero ---------- */
      .a-hero{ position:relative; overflow:hidden; padding:110px 0 70px; }
      .a-hero::before{ content:''; position:absolute; width:600px; height:600px; background:radial-gradient(circle,rgba(201,162,39,0.15) 0%,transparent 70%); top:-140px; right:-140px; pointer-events:none; }
      .a-hero::after{ content:''; position:absolute; width:420px; height:420px; background:radial-gradient(circle,rgba(122,149,105,0.13) 0%,transparent 70%); bottom:-40px; left:2%; pointer-events:none; }
      .a-grid{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:56px; align-items:center; position:relative; z-index:1; }
      @media (max-width:940px){ .a-grid{ grid-template-columns:1fr; } }
      .tech-pills{ display:flex; flex-wrap:wrap; gap:8px; margin-top:26px; }

      .panel{ background:var(--cm-bg-2); border:1px solid var(--cm-line); border-radius:20px; padding:26px; }
      .panel-title{ font-family:var(--cm-serif); font-size:17px; font-weight:600; color:var(--cm-ink); margin-bottom:18px; }
      .feature-list{ display:flex; flex-direction:column; gap:10px; }
      .feature-item{ display:flex; align-items:flex-start; gap:12px; padding:13px 15px; background:rgba(243,234,217,0.02); border:1px solid var(--cm-line-soft); border-radius:12px; transition:border-color .2s,background .2s; }
      .feature-item:hover{ border-color:rgba(201,162,39,0.3); background:rgba(201,162,39,0.04); }
      .fi-icon{ width:32px; height:32px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
      .fi-content h4{ font-family:var(--cm-serif); font-size:13.5px; font-weight:600; color:var(--cm-ink); margin-bottom:2px; }
      .fi-content p{ font-size:12px; color:var(--cm-ink-dim); line-height:1.5; }

      /* ---------- Stats ---------- */
      .stats-wrap{ border-top:1px solid var(--cm-line); border-bottom:1px solid var(--cm-line); background:var(--cm-bg-2); }
      .stats-inner{ padding:56px 0; display:grid; grid-template-columns:repeat(4,1fr); gap:18px; }
      @media (max-width:768px){ .stats-inner{ grid-template-columns:repeat(2,1fr); } }
      .stat-card{ text-align:center; padding:22px 14px; background:rgba(243,234,217,0.02); border:1px solid var(--cm-line-soft); border-radius:14px; }
      .stat-num{ font-family:var(--cm-serif); font-size:2.1rem; font-weight:700; margin-bottom:4px; color:var(--cm-brass-lt); }
      .stat-label{ font-size:11px; color:var(--cm-ink-faint); text-transform:uppercase; letter-spacing:0.1em; font-family:var(--cm-mono); }

      /* ---------- Philosophy ---------- */
      .phil-grid{ display:grid; grid-template-columns:0.8fr 1.2fr; gap:56px; margin-top:36px; }
      @media (max-width:900px){ .phil-grid{ grid-template-columns:1fr; } }
      .phil-list{ display:flex; flex-direction:column; gap:20px; }
      .phil-row{ display:flex; gap:14px; align-items:flex-start; }
      .phil-mark{ font-family:var(--cm-mono); font-size:12px; color:var(--cm-brass-lt); padding-top:3px; }
      .phil-row p{ font-size:14px; color:var(--cm-ink-dim); line-height:1.7; }
      .phil-row strong{ color:var(--cm-ink); font-family:var(--cm-serif); font-weight:600; }

      /* ---------- Tech stack ---------- */
      .tech-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:36px; }
      @media (max-width:768px){ .tech-grid{ grid-template-columns:1fr; } }
      .tc-head{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }
      .tc-icon{ width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:17px; }
      .tc-label{ font-size:10px; color:var(--cm-ink-faint); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:2px; font-family:var(--cm-mono); }
      .tc-name{ font-family:var(--cm-serif); font-size:15px; font-weight:600; color:var(--cm-ink); }
      .tc-desc{ font-size:12px; color:var(--cm-ink-dim); line-height:1.6; }

      /* ---------- CTA ---------- */
      .cta-wrap{ padding:90px 0; text-align:center; position:relative; overflow:hidden; }
      .cta-wrap::before{ content:''; position:absolute; width:640px; height:320px; background:radial-gradient(ellipse,rgba(201,162,39,0.12) 0%,transparent 70%); top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none; }
      .cta-inner{ position:relative; z-index:1; max-width:520px; margin:0 auto; }
      .cta-btns{ display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:26px; }
    </style>
  </head>

  <body class="cm2-body">
    <%- include("../partials/navbar") %>

    <main>

      <!-- HERO -->
      <section class="a-hero">
        <div class="cm2-wrap a-grid">
          <div>
            <span class="cm2-eyebrow"><span class="sq"></span>About
              ChessMaster</span>
            <h1 class="cm2-h1">
              A full-stack chessboard,<br>
              <span class="cm2-accent">built by hand.</span>
            </h1>
            <p class="cm2-sub" style="max-width:none;">
              No chess.com API, no drag-and-drop library, no framework doing
              the hard part for us. ChessMaster is EJS, vanilla JavaScript,
              Express routes, Socket.IO, and MongoDB — real move validation
              and a real AI opponent, written from scratch.
            </p>
            <div class="tech-pills">
              <span class="cm2-pill cm2-pill-brass">Node.js</span>
              <span class="cm2-pill cm2-pill-sage">Express</span>
              <span class="cm2-pill cm2-pill-rust">MongoDB</span>
              <span class="cm2-pill cm2-pill-brass">EJS</span>
              <span class="cm2-pill cm2-pill-sage">Socket.IO</span>
              <span class="cm2-pill cm2-pill-rust">Stockfish</span>
            </div>
          </div>

          <div class="panel">
            <div class="panel-title">What's inside</div>
            <div class="feature-list">
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(201,162,39,0.15);">♟</div>
                <div class="fi-content">
                  <h4>Interactive Board</h4>
                  <p>Click or drag pieces, legal move hints, check
                    highlights.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(122,149,105,0.15);">🤖</div>
                <div class="fi-content">
                  <h4>32 AI Bots (Stockfish)</h4>
                  <p>Rated 100–3200, powered by the world's strongest
                    engine.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(181,84,31,0.16);">🌐</div>
                <div class="fi-content">
                  <h4>Online Multiplayer</h4>
                  <p>Live games over Socket.IO, no page refresh required.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(201,162,39,0.15);">🧑‍🤝‍🧑</div>
                <div class="fi-content">
                  <h4>Friends & Challenges</h4>
                  <p>Search players, send requests, challenge from your
                    list.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(122,149,105,0.15);">⏱</div>
                <div class="fi-content">
                  <h4>Time Controls</h4>
                  <p>Rapid, Blitz, Bullet — full clock logic with increment.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(181,84,31,0.16);">🎨</div>
                <div class="fi-content">
                  <h4>Board Themes</h4>
                  <p>6 themes saved per user — Classic to Walnut.</p>
                </div>
              </div>
              <div class="feature-item">
                <div class="fi-icon"
                  style="background:rgba(201,162,39,0.15);">🏆</div>
                <div class="fi-content">
                  <h4>Leaderboard & Ratings</h4>
                  <p>Every game saved to MongoDB with wins, losses, draws.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="cm2-wrap"><div class="cm2-divider"></div></div>

      <!-- STATS -->
      <div class="stats-wrap">
        <div class="cm2-wrap stats-inner">
          <div class="stat-card"><div class="stat-num">32</div><div
              class="stat-label">AI Bots</div></div>
          <div class="stat-card"><div class="stat-num">6</div><div
              class="stat-label">Board Themes</div></div>
          <div class="stat-card"><div class="stat-num">3</div><div
              class="stat-label">Time Controls</div></div>
          <div class="stat-card"><div class="stat-num">100%</div><div
              class="stat-label">Free</div></div>
        </div>
      </div>

      <!-- PHILOSOPHY -->
      <section class="cm2-section">
        <div class="cm2-wrap">
          <span class="cm2-eyebrow"><span class="sq"></span>Why it's built this
            way</span>
          <h2 class="cm2-h2">Every piece has a reason to be there</h2>
          <div class="phil-grid">
            <p class="cm2-sub" style="max-width:none;">
              Chess sites are usually one of two things: a bloated SaaS
              product, or a bare board demo with no accounts and no memory.
              ChessMaster sits in between — small enough to read in an
              afternoon, complete enough to actually play on.
            </p>
            <div class="phil-list">
              <div class="phil-row">
                <span class="phil-mark">01</span>
                <p><strong>Sessions, not tokens.</strong> Login uses signed,
                  MongoDB-backed sessions — your game state survives a
                  refresh without any client-side auth logic.</p>
              </div>
              <div class="phil-row">
                <span class="phil-mark">02</span>
                <p><strong>Rooms, not polling.</strong> Online games run on
                  Socket.IO rooms — moves push to your opponent the instant
                  you make them, no refresh, no delay.</p>
              </div>
              <div class="phil-row">
                <span class="phil-mark">03</span>
                <p><strong>A real engine, not a script.</strong> Bots aren't
                  scripted "AI" — they're Stockfish running in a Web Worker,
                  tuned across 32 rating bands.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="cm2-wrap"><div class="cm2-divider"></div></div>

      <!-- TECH STACK -->
      <section class="cm2-section">
        <div class="cm2-wrap">
          <span class="cm2-eyebrow"><span class="sq"></span>Tech stack</span>
          <h2 class="cm2-h2">Built with modern web tech</h2>
          <p class="cm2-sub">No React, no Next.js — server-rendered pages,
            real chess logic, and a live connection where it matters.</p>

          <div class="tech-grid">
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(201,162,39,0.15);">🟢</div>
                <div><div class="tc-label">Runtime</div><div
                    class="tc-name">Node.js</div></div>
              </div>
              <p class="tc-desc">Server-side JavaScript runtime powering the
                entire backend.</p>
            </div>
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(122,149,105,0.15);">⚡</div>
                <div><div class="tc-label">Framework</div><div
                    class="tc-name">Express.js</div></div>
              </div>
              <p class="tc-desc">Handles routing, middleware, sessions, and API
                endpoints.</p>
            </div>
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(181,84,31,0.16);">🍃</div>
                <div><div class="tc-label">Database</div><div
                    class="tc-name">MongoDB</div></div>
              </div>
              <p class="tc-desc">Stores users, games, ratings, and settings with
                Mongoose.</p>
            </div>
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(201,162,39,0.15);">📄</div>
                <div><div class="tc-label">Templating</div><div
                    class="tc-name">EJS</div></div>
              </div>
              <p class="tc-desc">Server-side HTML rendering with dynamic data
                injection.</p>
            </div>
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(122,149,105,0.15);">🔌</div>
                <div><div class="tc-label">Realtime</div><div
                    class="tc-name">Socket.IO</div></div>
              </div>
              <p class="tc-desc">Powers online multiplayer rooms and live move
                syncing.</p>
            </div>
            <div class="cm2-card">
              <div class="tc-head">
                <div class="tc-icon"
                  style="background:rgba(181,84,31,0.16);">🤖</div>
                <div><div class="tc-label">AI Engine</div><div
                    class="tc-name">Stockfish</div></div>
              </div>
              <p class="tc-desc">World's strongest chess engine, run client-side
                via a Web Worker.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="cta-wrap">
        <div class="cta-inner">
          <h2 class="cm2-h1" style="font-size:clamp(1.8rem,4vw,2.8rem);">
            Ready to make<br><span class="cm2-accent">your first move?</span>
          </h2>
          <p class="cm2-sub" style="margin:0 auto;">
            Free to play, forever. Create an account and jump straight to the
            board.
          </p>
          <div class="cta-btns">
            <a href="<%= currentUser ? '/play' : '/register' %>"
              class="cm2-btn cm2-btn-primary">
              ♟ <%= currentUser ? 'Play Now' : 'Get Started Free' %>
            </a>
            <a href="/" class="cm2-btn cm2-btn-secondary">Back to Home</a>
          </div>
        </div>
      </div>

    </main>
    <%- include("../partials/footer") %>
  </body>
</html>