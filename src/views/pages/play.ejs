                        <button type="button" id="selectHumanBtn"
                            class="mode-btn-friend">
                            Play vs Friend
                        </button>
                    </article>

                    <article class="mode-card bot">
                        <span class="mode-icon">🤖</span>
                        <h3>vs Computer</h3>
                        <p>Challenge one of 32 AI bots from 100 to 3200
                            rating.</p>
                        <button type="button" id="selectBotBtn"
                            class="mode-btn-bot">
                            Play vs Bot
