<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ChessMaster | Leaderboard</title>
        <link rel="stylesheet" href="/css/style.css">
        <link
            href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap"
            rel="stylesheet">
        <style>*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:var(--cm-bg);
    color:var(--cm-ink);
}

/* ==========================
        PAGE
========================== */

.page-wrap{
    max-width:1200px;
    margin:auto;
    padding:0 24px 80px;
}

/* ==========================
        HERO
========================== */

.page-head{

    margin:0 -24px 40px;

    padding:60px 40px 35px;

    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:30px;
    flex-wrap:wrap;

    border-bottom:1px solid var(--cm-line);

    background:
    linear-gradient(
        135deg,
        rgba(201,162,39,.10),
        rgba(122,149,105,.06),
        transparent
    );

    position:relative;
    overflow:hidden;

}

.page-head::before{

    content:'';

    position:absolute;

    width:700px;
    height:700px;

    right:-180px;
    top:-260px;

    background:
    radial-gradient(circle,
    rgba(201,162,39,.12),
    transparent 70%);

}

.page-head>*{

    position:relative;
    z-index:2;

}

.kicker{

    font-family:'JetBrains Mono',monospace;

    font-size:11px;

    letter-spacing:.18em;

    text-transform:uppercase;

    color:var(--cm-brass-lt);

    display:block;

    margin-bottom:12px;

}

.page-title{

    font-family:'Fraunces',serif;

    font-size:clamp(2.4rem,5vw,3.4rem);

    font-weight:700;

    color:var(--cm-ink);

    margin-bottom:10px;

}

.page-sub{

    max-width:520px;

    line-height:1.8;

    color:var(--cm-ink-dim);

    font-size:15px;

}

/* ==========================
        BUTTONS
========================== */

.btn-primary{

    display:inline-flex;

    align-items:center;

    gap:8px;

    text-decoration:none;

    padding:13px 24px;

    border-radius:10px;

    font-size:13px;

    font-weight:700;

    color:#bbaf2dab;

    background:
    linear-gradient(
        135deg,
        var(--cm-brass),
        #b8871d
    );

    transition:.25s;

    box-shadow:
    0 8px 22px rgba(201,162,39,.28);

}

.btn-primary:hover{

    transform:translateY(-2px);

    box-shadow:
    0 12px 30px rgba(201,162,39,.45);

}

.btn-watch{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:8px 16px;

    border-radius:8px;

    font-size:12px;

    font-weight:600;

    text-decoration:none;

    color:var(--cm-ink);

    background:rgba(243,234,217,.03);

    border:1px solid var(--cm-line);

    transition:.25s;

}

.btn-watch:hover{

    background:rgba(201,162,39,.12);

    border-color:rgba(201,162,39,.45);

    color:var(--cm-brass-lt);

}

/* ==========================
      EMPTY STATE
========================== */

.empty-state{

    background:var(--cm-bg-2);

    border:1px solid var(--cm-line);

    border-radius:20px;

    padding:80px 40px;

    text-align:center;

}

.empty-icon{

    font-size:58px;

    margin-bottom:20px;

}

.empty-state h2{

    font-family:'Fraunces',serif;

    font-size:32px;

    margin-bottom:12px;

    color:var(--cm-ink);

}

.empty-state p{

    color:var(--cm-ink-dim);

    font-size:15px;

    line-height:1.8;

    margin-bottom:30px;

}
/* ==========================
      DESKTOP TABLE
========================== */

.table-wrap{

    background:var(--cm-bg-2);

    border:1px solid var(--cm-line);

    border-radius:18px;

    overflow:hidden;

    box-shadow:
    0 12px 28px rgba(0,0,0,.25);

}

table{

    width:100%;

    border-collapse:collapse;

}

thead{

    background:
    linear-gradient(
        180deg,
        rgba(201,162,39,.10),
        rgba(201,162,39,.04)
    );

    border-bottom:1px solid var(--cm-line);

}

th{

    padding:18px 20px;

    text-align:left;

    font-family:'JetBrains Mono',monospace;

    font-size:11px;

    text-transform:uppercase;

    letter-spacing:.12em;

    color:var(--cm-brass-lt);

}

td{

    padding:18px 20px;

    border-bottom:1px solid rgba(255,255,255,.05);

    font-size:14px;

    color:var(--cm-ink);

    transition:.25s;

}

tbody tr:last-child td{

    border-bottom:none;

}

tbody tr:hover td{

    background:rgba(201,162,39,.05);

}

.td-num{

    width:70px;

    font-weight:700;

    color:var(--cm-brass);

}

.td-player{

    font-weight:600;

    color:var(--cm-ink);

}

/* ==========================
          BADGES
========================== */

.badge-white{

    display:inline-flex;

    align-items:center;

    gap:6px;

    padding:6px 14px;

    border-radius:999px;

    background:
    rgba(243,234,217,.08);

    border:1px solid rgba(243,234,217,.18);

    color:#f5f5f5;

    font-size:12px;

    font-weight:700;

}

.badge-black{

    display:inline-flex;

    align-items:center;

    gap:6px;

    padding:6px 14px;

    border-radius:999px;

    background:
    rgba(0,0,0,.35);

    border:1px solid rgba(255,255,255,.10);

    color:#d1d5db;

    font-size:12px;

    font-weight:700;

}

.badge-draw{

    display:inline-flex;

    align-items:center;

    gap:6px;

    padding:6px 14px;

    border-radius:999px;

    background:
    rgba(201,162,39,.12);

    border:1px solid rgba(201,162,39,.35);

    color:var(--cm-brass-lt);

    font-size:12px;

    font-weight:700;

}
/* ==========================
        MOBILE CARDS
========================== */

.mobile-cards{

    display:none;

    flex-direction:column;

    gap:18px;

}

.game-card{

    display:block;

    text-decoration:none;

    color:inherit;

    background:var(--cm-bg-2);

    border:1px solid var(--cm-line);

    border-radius:18px;

    padding:22px;

    transition:.25s;

}

.game-card:hover{

    border-color:rgba(201,162,39,.35);

    transform:translateY(-3px);

    box-shadow:0 10px 24px rgba(0,0,0,.28);

}

.card-head{

    display:flex;

    justify-content:space-between;

    align-items:flex-start;

    gap:16px;

    margin-bottom:18px;

}

.match-num{

    font-family:'JetBrains Mono',monospace;

    font-size:11px;

    color:var(--cm-brass-lt);

    letter-spacing:.08em;

    text-transform:uppercase;

    margin-bottom:6px;

}

.card-head h3{

    font-family:'Fraunces',serif;

    font-size:22px;

    color:var(--cm-ink);

}

.card-meta{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:12px;

}

.meta-item{

    background:rgba(243,234,217,.03);

    border:1px solid rgba(255,255,255,.05);

    border-radius:12px;

    padding:14px;

}

.meta-item span{

    display:block;

    font-size:10px;

    text-transform:uppercase;

    letter-spacing:.10em;

    color:var(--cm-ink-faint);

    margin-bottom:5px;

}

.meta-item strong{

    color:var(--cm-ink);

    font-size:15px;

    font-weight:700;

}

/* ==========================
        RESPONSIVE
========================== */

@media(max-width:768px){

.page-head{

padding:45px 24px 30px;

margin:0 -24px 30px;

}

.page-title{

font-size:2.4rem;

}

.table-wrap{

display:none;

}

.mobile-cards{

display:flex;

}

}

@media(max-width:540px){

.card-meta{

grid-template-columns:1fr;

}

.page-wrap{

padding:0 18px 60px;

}

.page-head{

margin:0 -18px 25px;

padding:40px 18px 25px;

}

.page-title{

font-size:2rem;

}

.btn-primary{

width:100%;

justify-content:center;

}

}
    </style>
    </head>

    <body class="cm-body">
        <%- include("../partials/navbar") %><main>

            <div class="page-wrap">

                <div class="page-head">

                    <div>

                        <span class="kicker">♚ ChessMaster Ranking</span>

                        <h1 class="page-title">Leaderboard</h1>

                        <p class="page-sub">
                            Explore recently saved matches, winners, move count
                            and replay your favourite games.
                        </p>

                    </div>

                    <a href="/play" class="btn-primary">
                        ♟ Play New Match
                    </a>

                </div>

                <% if(!games || games.length===0){ %>

                <div class="empty-state">

                    <div class="empty-icon">🏆</div>

                    <h2>No Games Found</h2>

                    <p>
                        Play and save your first chess match to appear on the
                        leaderboard.
                    </p>

                    <a href="/play" class="btn-primary">
                        Start Playing
                    </a>

                </div>

                <% } else { %>

                <!-- =========================
        MOBILE CARDS
========================== -->

                <div class="mobile-cards">

                    <% games.forEach((game,index)=>{ %>

                    <a href="/game/<%= game._id %>" class="game-card">

                        <div class="card-head">

                            <div>

                                <div class="match-num">
                                    Match #<%= index+1 %>
                                </div>

                                <h3>
                                    <%= game.whitePlayer %> vs <%=
                                    game.blackPlayer %>
                                </h3>

                            </div>

                            <div>

                                <% if(game.winner==="white"){ %>

                                <span class="badge-white">
                                    ⬜ White
                                </span>

                                <% }else if(game.winner==="black"){ %>

                                <span class="badge-black">
                                    ⬛ Black
                                </span>

                                <% }else{ %>

                                <span class="badge-draw">
                                    🤝 Draw
                                </span>

                                <% } %>

                            </div>

                        </div>

                        <div class="card-meta">

                            <div class="meta-item">
                                <span>Moves</span>
                                <strong><%= game.totalMoves %></strong>
                            </div>

                            <div class="meta-item">
                                <span>Date</span>
                                <strong><%= new
                                    Date(game.createdAt).toLocaleDateString()
                                    %></strong>
                            </div>

                            <div class="meta-item">
                                <span>Mode</span>
                                <strong><%= game.timeMode || "Classic"
                                    %></strong>
                            </div>

                            <div class="meta-item">
                                <span>Time</span>
                                <strong><%= game.timeControl || "-" %></strong>
                            </div>

                        </div>

                    </a>

                    <% }) %>

                </div>

                <!-- =========================
      DESKTOP TABLE
========================== -->

                <div class="table-wrap">

                    <table>

                        <thead>

                            <tr>

                                <th>#</th>

                                <th>White Player</th>

                                <th>Black Player</th>

                                <th>Winner</th>

                                <th>Moves</th>

                                <th>Date</th>

                                <th>Replay</th>

                            </tr>

                        </thead>

                        <tbody>

                            <% games.forEach((game,index)=>{ %>

                            <tr>

                                <td class="td-num">

                                    <% if(index===0){ %>🥇
                                    <% }else if(index===1){ %>🥈
                                    <% }else if(index===2){ %>🥉
                                    <% }else{ %>
                                    <%= index+1 %>
                                    <% } %>

                                </td>

                                <td class="td-player">
                                    <%= game.whitePlayer %>
                                </td>

                                <td class="td-player">
                                    <%= game.blackPlayer %>
                                </td>

                                <td>

                                    <% if(game.winner==="white"){ %>

                                    <span class="badge-white">
                                        ⬜ White
                                    </span>

                                    <% }else if(game.winner==="black"){ %>

                                    <span class="badge-black">
                                        ⬛ Black
                                    </span>

                                    <% }else{ %>

                                    <span class="badge-draw">
                                        🤝 Draw
                                    </span>

                                    <% } %>

                                </td>

                                <td>
                                    <%= game.totalMoves %>
                                </td>

                                <td>
                                    <%= new
                                    Date(game.createdAt).toLocaleDateString() %>
                                </td>

                                <td>

                                    <a href="/game/<%= game._id %>"
                                        class="btn-watch">

                                        ▶ Watch

                                    </a>

                                </td>

                            </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

                <% } %>

            </div>

        </main>

        <%- include("../partials/footer") %>
    </body>
</html>