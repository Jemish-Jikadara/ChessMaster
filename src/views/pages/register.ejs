<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ChessMaster | Register</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body class="cm-body">

        <%- include("../partials/navbar") %>

        <main class="cm-auth-page">
            <section class="cm-auth-card">
                <div class="cm-auth-head">
                    <span class="cm-kicker">Create Account</span>
                    <h1>Join ChessMaster</h1>
                    <p>Create your player account to save games, ratings, and
                        future online matches.</p>
                </div>

                <% if (error && error.length > 0) { %>
                <div class="cm-alert cm-alert-error"><%= error[0] %></div>
                <% } %>

                <% if (success && success.length > 0) { %>
                <div class="cm-alert cm-alert-success"><%= success[0] %></div>
                <% } %>

                <form action="/register" method="POST" class="cm-auth-form">
                    <label>
                        Username
                        <input type="text" name="username"
                            placeholder="Enter username" required>
                    </label>

                    <label>
                        Email
                        <input type="email" name="email"
                            placeholder="Enter email" required>
                    </label>

                    <label>
                        Password
                        <input type="password" name="password"
                            placeholder="Enter password" required>
                    </label>

                    <label>
                        Confirm Password
                        <input type="password" name="confirmPassword"
                            placeholder="Confirm password" required>
                    </label>

                    <button type="submit" class="cm-btn cm-btn-primary">Create
                        Account</button>
                </form>

                <p class="cm-auth-switch">
                    Already have an account?
                    <a href="/login">Login</a>
                </p>
            </section>
        </main>

        <%- include("../partials/footer") %>

    </body>
</html>
