<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ChessMaster | Status</title>

        <link rel="stylesheet" href="/css/style.css">

        <style>body{
    background:#080810;
    color:#f3f4f6;
    font-family:Inter,sans-serif;
    margin:0;
}

.status-container{
    width:min(96vw,1450px);
    margin:20px auto;
    padding:15px;
}

.status-title{
    font-size:32px;
    font-weight:800;
    margin-bottom:18px;
}

/* ---------------- Tabs ---------------- */

.mode-tabs{
    display:flex;
    gap:10px;
    margin-bottom:18px;
    flex-wrap:wrap;
}

.mode-btn{
    padding:10px 22px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    background:#181825;
    color:#9ca3af;
    transition:.25s;
    font-size:14px;
    font-weight:600;
}

.mode-btn.active{
    background:#7c3aed;
    color:#fff;
}

.mode-btn:hover{
    transform:translateY(-2px);
}

/* -------- Main Layout -------- */

.main-layout{
    display:grid;
    grid-template-columns:360px 1fr;
    gap:18px;
    align-items:start;
}

/* -------- Cards -------- */

.stats-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:12px;
}

.stat-card{
    background:#13131d;
    border:1px solid rgba(255,255,255,.06);
    border-radius:12px;
    padding:16px;
    transition:.25s;
}

.stat-card:hover{
    transform:translateY(-3px);
    border-color:#7c3aed;
}

.stat-title{
    color:#9ca3af;
    font-size:12px;
    margin-bottom:6px;
}

.stat-value{
    font-size:24px;
    font-weight:800;
}

/* -------- Graph -------- */

.graph-box{
    background:#13131d;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.06);
    padding:18px;
    min-height:460px;

    display:flex;
    flex-direction:column;
}

.graph-title{
    font-size:18px;
    font-weight:700;
    margin-bottom:14px;
}

.graph-box canvas{
    width:100%!important;
    height:390px!important;
}

/* -------- Tablets -------- */

@media(max-width:1100px){

.main-layout{
    grid-template-columns:1fr;
}

.graph-box canvas{
    height:320px!important;
}

}

/* -------- Mobile -------- */

@media(max-width:700px){

.status-container{
    width:100%;
    padding:12px;
}

.status-title{
    font-size:25px;
}

.mode-tabs{
    justify-content:center;
}

.mode-btn{
    flex:1;
    min-width:90px;
    padding:10px;
}

.stats-grid{
    grid-template-columns:repeat(2,1fr);
    gap:10px;
}

.stat-card{
    padding:14px;
}

.stat-value{
    font-size:20px;
}

.graph-box{
    padding:12px;
}

.graph-box canvas{
    height:250px!important;
}

}

/* -------- Small Mobile -------- */

@media(max-width:420px){

.stats-grid{
    grid-template-columns:1fr 1fr;
}

.stat-title{
    font-size:11px;
}

.stat-value{
    font-size:18px;
}

.mode-btn{
    font-size:13px;
}

.graph-box canvas{
    height:220px!important;
}

}
    </style>

    </head>

    <body>

        <%- include("../partials/navbar") %>

        <div class="status-container">

            <div class="status-title">
                Rating Status
            </div>

            <div class="mode-tabs">

                <button class="mode-btn active"
                    onclick="changeMode('rapid',this)">
                    Rapid
                </button>

                <button class="mode-btn" onclick="changeMode('blitz',this)">
                    Blitz
                </button>

                <button class="mode-btn" onclick="changeMode('bullet',this)">
                    Bullet
                </button>

            </div>

            <div class="dashboard">
                <div class="main-layout">

                    <div class="stats-grid">

                        <div class="stat-card">
                            <div class="stat-title">Rating</div>
                            <div class="stat-value" id="rating">0</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-title">Peak</div>
                            <div class="stat-value" id="peak">0</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-title">Games</div>
                            <div class="stat-value" id="games">0</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-title">Wins</div>
                            <div class="stat-value" id="wins">0</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-title">Losses</div>
                            <div class="stat-value" id="losses">0</div>
                        </div>

                        <div class="stat-card">
                            <div class="stat-title">Draws</div>
                            <div class="stat-value" id="draws">0</div>
                        </div>

                        <div class="stat-card" style="grid-column:span 2;">
                            <div class="stat-title">Win Rate</div>
                            <div class="stat-value" id="winrate">0%</div>
                        </div>

                    </div>

                    <div class="graph-box">

                        <div class="graph-title">
                            Rating History
                        </div>

                        <div class="chart-wrapper">
                            <canvas id="ratingChart"></canvas>
                        </div>

                    </div>
                </div>

            </div>

        </div>

        <%- include("../partials/footer") %>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
const rapidHistory = <%- JSON.stringify(rapidHistory) %>;
const blitzHistory = <%- JSON.stringify(blitzHistory) %>;
const bulletHistory = <%- JSON.stringify(bulletHistory) %>;

const data = {

rapid:{
rating:<%= rapidRating %>,
peak:<%= rapidPeak %>,
games:<%= rapidGames %>,
wins:<%= rapidWins %>,
losses:<%= rapidLosses %>,
draws:<%= rapidDraws %>,
win:"<%= rapidWinRate %>%"
},

blitz:{
rating:<%= blitzRating %>,
peak:<%= blitzPeak %>,
games:<%= blitzGames %>,
wins:<%= blitzWins %>,
losses:<%= blitzLosses %>,
draws:<%= blitzDraws %>,
win:"<%= blitzWinRate %>%"
},

bullet:{
rating:<%= bulletRating %>,
peak:<%= bulletPeak %>,
games:<%= bulletGames %>,
wins:<%= bulletWins %>,
losses:<%= bulletLosses %>,
draws:<%= bulletDraws %>,
win:"<%= bulletWinRate %>%"
}

};

const ctx=document.getElementById("ratingChart").getContext("2d");

const gradient=ctx.createLinearGradient(0,0,0,450);
gradient.addColorStop(0,"rgba(139,92,246,.45)");
gradient.addColorStop(1,"rgba(139,92,246,0)");

let chart=new Chart(ctx,{

type:"line",

data:{
labels:[],
datasets:[{

label:"Rapid Rating",

data:[],

borderColor:"#8b5cf6",

backgroundColor:gradient,

fill:true,

borderWidth:3,

tension:.45,

pointRadius:5,

pointHoverRadius:8,

pointBackgroundColor:"#8b5cf6",

pointBorderColor:"#fff",

pointBorderWidth:2

}]
},

options:{

responsive:true,

maintainAspectRatio:false,

animation:{
duration:1000
},

interaction:{
mode:"index",
intersect:false
},

plugins:{

legend:{
display:false
},

tooltip:{
backgroundColor:"#111827",
titleColor:"#fff",
bodyColor:"#fff",
borderColor:"#8b5cf6",
borderWidth:1,
padding:12
}

},

scales:{

x:{
ticks:{
color:"#9ca3af"
},
grid:{
color:"rgba(255,255,255,.05)"
}
},

y:{
ticks:{
color:"#9ca3af"
},
grid:{
color:"rgba(255,255,255,.05)"
}
}

}

}

});

function changeMode(mode,btn){

document.querySelectorAll(".mode-btn").forEach(x=>{
x.classList.remove("active");
});

btn.classList.add("active");

let history=[];

if(mode==="rapid"){
history=rapidHistory;
}

if(mode==="blitz"){
history=blitzHistory;
}

if(mode==="bullet"){
history=bulletHistory;
}

if(history.length===0){
history=[1200];
}

chart.data.labels=history.map((_,i)=>i+1);

chart.data.datasets[0].data=history;

chart.data.datasets[0].label=mode.toUpperCase()+" Rating";

/* Auto Zoom */

const min=Math.min(...history);
const max=Math.max(...history);

chart.options.scales.y.min=min-5;
chart.options.scales.y.max=max+5;

chart.update();

document.getElementById("rating").textContent=data[mode].rating;

document.getElementById("peak").textContent=data[mode].peak;

document.getElementById("games").textContent=data[mode].games;

document.getElementById("wins").textContent=data[mode].wins;

document.getElementById("losses").textContent=data[mode].losses;

document.getElementById("draws").textContent=data[mode].draws;

document.getElementById("winrate").textContent=data[mode].win;

}

window.onload=()=>{

changeMode(
"rapid",
document.querySelector(".mode-btn")
);

};
</script>

    </body>
</html>