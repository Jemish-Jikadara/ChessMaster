<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ChessMaster | Status</title>

        <link rel="stylesheet" href="/css/style.css">

        <style>
        body{
            background:#080810;
            color:#f3f4f6;
            font-family:Inter,sans-serif;
        }

        .status-container{
            max-width:1100px;
            margin:40px auto;
            padding:20px;
        }

        .status-title{
            font-size:42px;
            font-weight:800;
            margin-bottom:30px;
        }

        /* ---------- Tabs ---------- */

        .mode-tabs{
            display:flex;
            gap:15px;
            margin-bottom:35px;
        }

        .mode-btn{
            padding:12px 30px;
            border-radius:10px;
            cursor:pointer;
            border:1px solid rgba(255,255,255,.08);
            background:#16161f;
            color:#9ca3af;
            transition:.25s;
            font-weight:600;
        }

        .mode-btn.active{
            background:#7c3aed;
            color:white;
            border-color:#7c3aed;
        }

        .mode-btn:hover{
            transform:translateY(-2px);
        }

        /* ---------- Cards ---------- */

        .stats-grid{
            display:grid;
            grid-template-columns:repeat(4,1fr);
            gap:20px;
            margin-bottom:35px;
        }

        .stat-card{
            background:#14141d;
            border:1px solid rgba(255,255,255,.06);
            border-radius:14px;
            padding:25px;
        }

        .stat-title{
            color:#9ca3af;
            font-size:13px;
            margin-bottom:10px;
        }

        .stat-value{
            font-size:35px;
            font-weight:800;
        }

        /* ---------- Graph ---------- */

        .graph-box{
            background:#14141d;
            border-radius:15px;
            border:1px solid rgba(255,255,255,.06);
            padding:30px;
        }

        .graph-title{
            font-size:20px;
            margin-bottom:20px;
            font-weight:700;
        }

        .graph-placeholder{
            height:350px;
            border-radius:12px;
            border:2px dashed rgba(255,255,255,.15);

            display:flex;
            justify-content:center;
            align-items:center;

            color:#6b7280;
            font-size:20px;
        }

        @media(max-width:850px){

            .stats-grid{
                grid-template-columns:repeat(2,1fr);
            }

        }

        @media(max-width:550px){

            .stats-grid{
                grid-template-columns:1fr;
            }

            .mode-tabs{
                flex-direction:column;
            }

        }

    </style>

    </head>

    <body>

        <%- include("../partials/navbar") %>

        <div class="status-container">

            <div class="status-title">
                Rating Status
            </div>

            <div class="mode-tabs">

                <button class="mode-btn active"
                    onclick="changeMode('rapid',this)">
                    Rapid
                </button>

                <button class="mode-btn" onclick="changeMode('blitz',this)">
                    Blitz
                </button>

                <button class="mode-btn" onclick="changeMode('bullet',this)">
                    Bullet
                </button>

            </div>

            <div class="stats-grid">

                <div class="stat-card">
                    <div class="stat-title">Rating</div>
                    <div class="stat-value" id="rating">1240</div>
                </div>

                <div class="stat-card">
                    <div class="stat-title">Peak Rating</div>
                    <div class="stat-value" id="peak">1291</div>
                </div>

                <div class="stat-card">
                    <div class="stat-title">Games</div>
                    <div class="stat-value" id="games">145</div>
                </div>

                <div class="stat-card">
                    <div class="stat-title">Win Rate</div>
                    <div class="stat-value" id="winrate">63%</div>
                </div>

            </div>

            <div class="graph-box">

                <div class="graph-title">
                    Rating History
                </div>

                <div class="graph-placeholder">

                    📈 Rating Graph Coming Soon

                </div>

            </div>

        </div>

        <%- include("../partials/footer") %>

        <script>

const data={

rapid:{
rating:1240,
peak:1291,
games:145,
win:"63%"
},

blitz:{
rating:1185,
peak:1224,
games:95,
win:"58%"
},

bullet:{
rating:1098,
peak:1140,
games:40,
win:"51%"
}

};

function changeMode(mode,btn){

document.querySelectorAll(".mode-btn").forEach(b=>{
b.classList.remove("active");
});

btn.classList.add("active");

document.getElementById("rating").textContent=data[mode].rating;
document.getElementById("peak").textContent=data[mode].peak;
document.getElementById("games").textContent=data[mode].games;
document.getElementById("winrate").textContent=data[mode].win;

}

</script>

    </body>
</html>