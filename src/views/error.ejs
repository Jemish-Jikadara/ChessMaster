<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>ChessMaster | Page Not Found</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body class="bg-gray-950 text-white">

        <%- include("./partials/navbar") %>

        <main class="min-h-[80vh] flex items-center justify-center px-6">
            <section class="max-w-2xl text-center">
                <p class="text-yellow-400 font-semibold mb-4">
                    404 Error
                </p>

                <h1 class="text-5xl md:text-7xl font-extrabold mb-6">
                    Wrong Move.
                </h1>

                <p class="text-gray-400 text-lg leading-8 mb-8">
                    This page does not exist. The path you opened is not a legal
                    move on this board.
                </p>

                <div class="flex flex-wrap justify-center gap-4">
                    <a
                        href="/"
                        class="bg-yellow-400 text-gray-950 px-7 py-4 rounded-xl font-bold hover:bg-yellow-300 transition">
                        Go Home
                    </a>

                    <a
                        href="/play"
                        class="border border-white/20 text-white px-7 py-4 rounded-xl font-bold hover:border-yellow-400 hover:text-yellow-400 transition">
                        Play Chess
                    </a>
                </div>
            </section>
        </main>

        <%- include("./partials/footer") %>

    </body>
</html>
