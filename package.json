{
  "name": "chess-master",
  "version": "1.0.0",
  "description": "A full-stack chess game using Node.js, Express, EJS, Tailwind CSS, JavaScript, and MongoDB.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --no-deprecation server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch"
  },
  "keywords": [
    "chess",
    "nodejs",
    "express",
    "ejs",
    "tailwind",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^4.6.0",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.18.3",
    "express-session": "^1.19.0",
    "mongoose": "^9.6.2",
    "nodemailer": "^8.0.9",
    "socket.io": "^4.8.3",
    "tailwind": "^4.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1"
